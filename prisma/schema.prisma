generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum OtpType {
  PASSWORD_RESET
  EMAIL_VERIFY
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  SOLD
  DELETED
}

enum FlagReason {
  MISLEADING
  INAPPROPRIATE
  FRAUDULENT
  DUPLICATE
  SPAM
  WRONG_PRICE
  OTHER
}

enum FlagStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
  LPG
  CNG
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
  CVT
  SEMI_AUTOMATIC
}

enum BodyType {
  SEDAN
  SUV
  HATCHBACK
  COUPE
  CONVERTIBLE
  WAGON
  VAN
  TRUCK
  BUS
  OTHER
}

enum ConditionType {
  NEW
  USED
  CERTIFIED_PRE_OWNED
}

enum DealerStatus {
  PENDING_VERIFICATION
  VERIFIED
  SUSPENDED
  REJECTED
}

enum SubscriptionTier {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

// ─── Role ───────────────────────────────────────────────

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  label       String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users UserRole[]

  @@map("roles")
}

// ─── UserRole (Join Table) ──────────────────────────────

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ─── User ───────────────────────────────────────────────

model User {
  id            String        @id @default(uuid())
  fullName      String
  email         String        @unique
  phone         String        @unique
  password      String
  accountStatus AccountStatus @default(ACTIVE)
  isVerified    Boolean       @default(false)
  suspendedAt   DateTime?
  suspendUntil  DateTime?
  suspendReason String?
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  roles          UserRole[]
  sessions       Session[]
  otpCodes       OtpCode[]
  dealer         Dealer?
  listings       Listing[]        @relation("SellerListings")
  flags          ListingFlag[]    @relation("UserFlags")
  moderatedFlags ListingFlag[]    @relation("ModeratorFlags")
  inquiries      ListingInquiry[] @relation("UserInquiries")
  views          ListingView[]

  @@index([accountStatus])
  @@index([email])
  @@map("users")
}

// ─── Session ────────────────────────────────────────────

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

// ─── OTP Code ───────────────────────────────────────────

model OtpCode {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code, type])
  @@map("otp_codes")
}

// ─── Dealer ─────────────────────────────────────────────

model Dealer {
  id                    String           @id @default(uuid())
  userId                String           @unique
  companyName           String
  tradeLicenseNumber    String?
  tradeLicenseUrl       String?
  contactEmail          String?
  contactPhone          String?
  address               String?
  city                  String?
  region                String?
  description           String?
  logoUrl               String?
  websiteUrl            String?
  status                DealerStatus     @default(PENDING_VERIFICATION)
  subscriptionTier      SubscriptionTier @default(FREE)
  subscriptionExpiresAt DateTime?
  verifiedAt            DateTime?
  rejectionReason       String?
  maxListings           Int              @default(10)
  totalListings         Int              @default(0)
  totalViews            Int              @default(0)
  totalInquiries        Int              @default(0)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[] @relation("DealerListings")

  @@index([status])
  @@index([subscriptionTier])
  @@index([city])
  @@map("dealers")
}

// ─── Listing ────────────────────────────────────────────

model Listing {
  id              String           @id @default(uuid())
  title           String
  description     String?
  sellerId        String
  dealerId        String?

  // Vehicle details
  make            String
  model           String
  year            Int
  mileage         Int
  price           Float
  currency        String           @default("SAR")
  negotiable      Boolean          @default(false)
  fuelType        FuelType?
  transmission    TransmissionType?
  bodyType        BodyType?
  condition       ConditionType    @default(USED)
  color           String?
  engineSize      String?
  horsepower      Int?
  doors           Int?
  cylinders       Int?
  vin             String?

  // Location
  city            String?
  region          String?

  // Status & moderation
  status          ListingStatus    @default(PENDING_REVIEW)
  rejectionReason String?

  // Featured
  isFeatured      Boolean          @default(false)
  featuredUntil   DateTime?

  // Counters (denormalized for performance)
  viewCount       Int              @default(0)
  inquiryCount    Int              @default(0)
  flagCount       Int              @default(0)

  // Timestamps
  expiresAt       DateTime?
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  seller    User            @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  dealer    Dealer?         @relation("DealerListings", fields: [dealerId], references: [id], onDelete: SetNull)
  images    ListingImage[]
  flags     ListingFlag[]
  views     ListingView[]
  inquiries ListingInquiry[]

  @@index([status])
  @@index([sellerId])
  @@index([dealerId])
  @@index([make, model])
  @@index([price])
  @@index([city])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("listings")
}

// ─── Listing Image ──────────────────────────────────────

model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_images")
}

// ─── Listing Flag ───────────────────────────────────────

model ListingFlag {
  id            String     @id @default(uuid())
  listingId     String
  flaggedById   String
  reason        FlagReason
  description   String?
  status        FlagStatus @default(PENDING)
  moderatorId   String?
  moderatorNote String?
  resolvedAt    DateTime?
  createdAt     DateTime   @default(now())

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  flaggedBy User    @relation("UserFlags", fields: [flaggedById], references: [id], onDelete: Cascade)
  moderator User?   @relation("ModeratorFlags", fields: [moderatorId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([flaggedById])
  @@index([status])
  @@map("listing_flags")
}

// ─── Listing View ───────────────────────────────────────

model ListingView {
  id        String   @id @default(uuid())
  listingId String
  viewerId  String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewer  User?   @relation(fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([viewerId])
  @@index([createdAt])
  @@map("listing_views")
}

// ─── Listing Inquiry ────────────────────────────────────

model ListingInquiry {
  id          String    @id @default(uuid())
  listingId   String
  userId      String
  message     String
  phone       String?
  email       String?
  isRead      Boolean   @default(false)
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation("UserInquiries", fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
  @@index([isRead])
  @@map("listing_inquiries")
}
